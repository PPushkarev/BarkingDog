
# --- Target Bot Configuration ---

TARGET_URL=
# Webhook endpoint of the AI bot being tested

AEGIS_SECRET_TOKEN=
# Security token passed in headers to authorize the scanner on the target bot

BOT_DOMAIN="Miami Auto Detailing services, booking, and pricing"
# Core business context for AI Judge to detect hallucinations or roleplay drift

# --- Scanning Engine Logic ---

DAEMON_MODE=true
# Set to true to enable continuous background scanning

SCAN_INTERVAL_HOURS=168
# Frequency of scans in hours when in daemon mode (168h = weekly)

SCAN_DELAY=0.5
# Pause in seconds between individual requests to prevent rate limiting

SCAN_CONCURRENCY=5
# Maximum number of parallel asynchronous requests to the target

# --- Telegram Notifications ---

TELEGRAM_BOT_TOKEN=
# The API token for the Telegram bot that will send the scan reports

TELEGRAM_CHAT_ID=
# Your personal Telegram chat or group ID to receive results

# --- AI Judge (Evaluation Layer) ---

AI_MODEL=gpt-4o
# The LLM model used for analyzing bot responses and mutating payloads

AI_TEMPERATURE=0.2
# Randomness setting (low temperature ensures more consistent and strict logic verdicts)

AI_API_KEY=
# Your LLM provider API key (e.g., OpenAI API Key)
